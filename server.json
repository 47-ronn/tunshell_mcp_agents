{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.47-ronn/remote-agents",
  "description": "Control fleets of remote machines via AI agents: exec, files, git, fleet ops, map/reduce.",
  "repository": {
    "url": "https://github.com/47-ronn/tunshell_mcp_agents",
    "source": "github"
  },
  "version": "0.1.7",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "remote-agents",
      "version": "0.1.7",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
