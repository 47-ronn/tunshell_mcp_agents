{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "remote-agents-relay",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "c49dfbd01e2226879e5157f43e3425df",

  "durable_objects": {
    "bindings": [
      {
        "name": "ROOM",
        "class_name": "Room"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Room"]
    }
  ],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
